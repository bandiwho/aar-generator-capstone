# Copy this file to .env and update the values for your environment.

# Keep mock mode true until the app flow is tested.
MOCK_LLM=true

# Set this when MOCK_LLM=false.
OPENAI_API_KEY=

# Keep this configurable so the team can use the model approved for class.
OPENAI_MODEL=gpt-5.4-mini

# App behavior.
APP_ENV=development
